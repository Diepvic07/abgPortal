{
  "framework": "nextjs",
  "regions": ["sin1"],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "abgalumni.vn" }],
      "destination": "https://www.abgalumni.vn/:path",
      "permanent": true
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/duplicate-reminder",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/discussion-reminder",
      "schedule": "*/5 * * * *"
    }
  ]
}
