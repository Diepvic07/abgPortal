{
  "name": "abg-alumni-connect",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "import-members": "tsx scripts/import-csv-members.ts",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:e2e:chromium": "playwright test --config=e2e/playwright.config.ts --project=chromium",
    "test:e2e:report": "playwright show-report e2e/playwright-report",
    "test:e2e:ci": "CI=true npm run test:e2e",
    "migrate-live": "npx tsx scripts/migrate-live-data.ts",
    "verify-migration": "npx tsx scripts/verify-migration.ts",
    "migrate:dating": "npx tsx scripts/migrate-dating-profiles.ts",
    "migrate:dating:dry": "npx tsx scripts/migrate-dating-profiles.ts --dry-run",
    "migrate:csv": "npx tsx scripts/migrate-csv-to-supabase.ts",
    "migrate:csv:dry": "npx tsx scripts/migrate-csv-to-supabase.ts --dry-run"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/typography": "^0.5.19",
    "@uiw/react-md-editor": "^4.0.11",
    "@vercel/blob": "^2.0.1",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.1",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
